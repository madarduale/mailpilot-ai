# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.ngrok-free.dev,.ngrok-free.app
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.ngrok-free.dev,https://*.ngrok-free.app
CORS_ALLOWED_ORIGINS=http://localhost:8081
CORS_ALLOW_CREDENTIALS=false
API_PAGE_SIZE=25
API_MAX_PAGE_SIZE=100

# PostgreSQL
DATABASE_URL=postgresql://mailpilot:mailpilot@localhost:5432/mailpilot

# Redis, Channels, and Celery
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
# Keep local Docker Redis memory-only to avoid host-filesystem fsync stalls.
# Production should use a managed, durable Redis deployment instead.
REDIS_APPENDONLY=no

# JWT
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30
JWT_SIGNING_KEY=replace-with-an-independent-long-random-value
AUTH_REGISTER_RATE=5/hour
AUTH_LOGIN_RATE=10/minute
AUTH_REFRESH_RATE=30/minute
AUTH_PASSWORD_CHANGE_RATE=5/hour
HEALTH_CHECK_RATE=60/minute

# Gmail OAuth
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/gmail/callback/
GOOGLE_OAUTH_SCOPES=openid,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/userinfo.profile,https://www.googleapis.com/auth/gmail.modify
GOOGLE_OAUTH_CLOCK_SKEW_SECONDS=30
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
GOOGLE_API_TIMEOUT_SECONDS=30
OAUTH_MOBILE_REDIRECT_SCHEMES=mailpilot

# Versioned Fernet keys, newest first. Never commit real keys.
OAUTH_TOKEN_ENCRYPTION_KEYS=

# Text generation through OpenRouter. Use explicit provider variables; values
# such as ${OPENROUTER_API_KEY} are not portable across .env parsers.
AI_TEXT_PROVIDER=openrouter
AI_AUDIO_PROVIDER=openrouter
OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_RESPONSES_MODEL=openai/gpt-5.6-terra
OPENROUTER_TRANSCRIPTION_MODEL=openai/whisper-1
OPENROUTER_TTS_MODEL=x-ai/grok-voice-tts-1.0
OPENROUTER_TTS_FALLBACK_MODELS=hexgrad/kokoro-82m,mistralai/voxtral-mini-tts-2603
# Voice identifiers are model-specific. "alloy" is supported by Voxtral Mini TTS.
OPENROUTER_TTS_VOICE=Eve
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=MailPilot AI

# Optional direct OpenAI fallback for a later production configuration.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_RESPONSES_MODEL=gpt-5.6-terra
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
AI_CONNECT_TIMEOUT_SECONDS=5
AI_READ_TIMEOUT_SECONDS=60
AI_WRITE_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_MAX_OUTPUT_TOKENS=512
NEW_EMAIL_NOTIFICATION_MAX_AGE_SECONDS=900

# Expo push notifications
EXPO_ACCESS_TOKEN=

# Observability and security
LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
